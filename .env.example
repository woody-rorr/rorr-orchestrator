PORT=4000

# AWS (SSM에서 Claude OAuth credentials 받기 + ECS 환경)
AWS_PROFILE=rorr-dev
AWS_REGION=us-east-1

# Claude CLI는 SSM의 OAuth credentials을 사용 (entrypoint.sh가 부팅 시 주입)
# SSM 경로 (기본): /rorr-mcp-infra/claude-credentials
# SSM_CLAUDE_PATH=/rorr-mcp-infra/claude-credentials

# Claude Code CLI 모델 (OAuth 형식). 미설정 시 CLI 기본.
LLM_MODEL=claude-sonnet-4-5

# MCP 서버들
MCP_INFRA_URL=http://mcp-agents-staging-alb-249976027.us-east-1.elb.amazonaws.com:5010/mcp
# MCP_FRONTEND_WEB_URL=
# MCP_FRONTEND_EXT_URL=
# MCP_BACKEND_API_URL=
# MCP_BACKEND_LOGIC_URL=
# MCP_BACKEND_SCHEMA_URL=

# GitHub OAuth App (Sign in with GitHub)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 세션 서명용 (없으면 SSM /rorr/session/secret 사용)
# SESSION_SECRET=
