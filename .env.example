PORT=4000

# LLM 공급자: bedrock(기본, AWS) 또는 anthropic(Anthropic API)
LLM_PROVIDER=bedrock

# Bedrock 사용 시 (AWS 자격증명은 ~/.aws/credentials 또는 환경변수 사용)
AWS_PROFILE=rorr-dev
AWS_REGION=us-east-1
LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Anthropic 사용 시 (Bedrock 안 쓰면)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-7

# MCP 서버들 (지금은 infra만)
MCP_INFRA_URL=http://mcp-agents-staging-alb-249976027.us-east-1.elb.amazonaws.com:5010/mcp
# MCP_BACKEND_URL=
# MCP_FRONTEND_URL=

# 사용자 신원 (인증 붙기 전 임시)
DEFAULT_USER_ID=woody@rorr.club
