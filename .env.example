PORT=4000

# AWS (SSM에서 Claude OAuth credentials 받기 + ECS 환경)
AWS_PROFILE=rorr-dev
AWS_REGION=us-east-1

# Claude CLI는 SSM의 OAuth credentials을 사용 (entrypoint.sh가 부팅 시 주입)
# SSM 경로 (기본): /rorr-mcp-infra/claude-credentials
# SSM_CLAUDE_PATH=/rorr-mcp-infra/claude-credentials

# Claude Code CLI 모델 (OAuth 형식). 미설정 시 CLI 기본.
LLM_MODEL=claude-sonnet-4-5

# MCP 서버들
MCP_INFRA_URL=http://mcp-agents-staging-alb-249976027.us-east-1.elb.amazonaws.com:5010/mcp
MCP_MIGRATION_URL=http://mcp-agents-staging-alb-249976027.us-east-1.elb.amazonaws.com:5011/mcp
MCP_WEB_URL=http://mcp-agents-staging-alb-249976027.us-east-1.elb.amazonaws.com:5007/mcp
# Notion MCP (호스티드 https://mcp.notion.com/mcp). headless 환경이라 OAuth 대신 Integration 토큰 사용.
MCP_NOTION_URL=https://mcp.notion.com/mcp
# NOTION_TOKEN=ntn_xxxxx   # Notion Internal Integration 토큰 (Bearer 접두사 자동 부착)
# MCP_FRONTEND_WEB_URL=
# MCP_FRONTEND_EXT_URL=
# MCP_BACKEND_API_URL=
# MCP_BACKEND_LOGIC_URL=
# MCP_BACKEND_SCHEMA_URL=

# GitHub OAuth App (Sign in with GitHub)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# 세션 서명용 (없으면 SSM /rorr/session/secret 사용)
# SESSION_SECRET=

# Teams 알림 (PR 생성 성공 시). RORR-Bot Gateway(Mac mini) 경유.
# 구조: 오케스트레이터(AWS) → Tailscale → RORR-Bot Gateway → Teams
# 게이트웨이 endpoint가 있어야 알림 활성화. 미설정 시 비활성(no-op).
# RORR_BOT_GATEWAY_URL=https://bot.rorr.club/tools/invoke
# RORR_BOT_AGENT_ID=main
# 봇 토큰: ECS에서는 SSM SecureString(RORR_BOT_TOKEN)에서 로드. 로컬은 아래 env로 override.
# RORR_BOT_TOKEN=
# 봇 토큰 SSM 경로 (기본: /rorr/teams/bot-token)
# SSM_RORR_BOT_TOKEN_PATH=/rorr/teams/bot-token
